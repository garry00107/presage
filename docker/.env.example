# NOTE: Save as docker/.env.example (no .py extension)

ENV_EXAMPLE_CONTENT = """
# LLM Backend
PPM_LLM_BACKEND=anthropic           # anthropic | openai | ollama | nvidia
PPM_LLM_MODEL=claude-sonnet-4-20250514

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...               # required if embedder_backend=openai
NVIDIA_API_KEY=nvapi-...            # automatically supports free NIM inference credits

# Embedder
PPM_EMBEDDER_BACKEND=openai         # openai | nomic | bge | nvidia
PPM_EMBEDDER_MODEL=text-embedding-3-small
PPM_EMBEDDER_DIM=1536

# Storage paths (override for docker volumes)
PPM_SQLITE_PATH=./ppm_data/ppm.db
PPM_QDRANT_PATH=./ppm_data/qdrant
PPM_KUZU_PATH=./ppm_data/kuzu

# Momentum tuning
PPM_DECAY_LAMBDA_BASE=0.85
PPM_CONTEXT_SWITCH_THRESHOLD=0.40
PPM_SLERP_STEP_SIZE=0.30

# Staging
PPM_SLOT_COUNT=10
PPM_AUTO_INJECT_THRESHOLD=0.80
PPM_HOT_THRESHOLD=0.50
PPM_MAX_INJECT_TOKENS=4096
PPM_SLOT_TTL_SECONDS=120

# Observability
PPM_LOG_LEVEL=INFO
PPM_METRICS_PORT=9090
PPM_OTEL_ENDPOINT=                  # set to enable tracing (e.g. http://jaeger:4317)
"""

